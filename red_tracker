# 카메라 영상
# → 빨간색만 추출
# → 빨간 물체 중심 찾기
# → 중심 좌표 출력
# → 나중에 그 좌표를 로봇팔 제어로 연결

1. 카메라 영상을 subscribe
2. OpenCV로 빨간색 영역 추출
3. 가장 큰 빨간 물체의 중심 좌표 계산
4. 화면에 원과 좌표를 표시
5. 터미널에 x, y 출력
6. 다음 단계에서 ROS 토픽으로 publish

먼저 이 파일을 만들어 주세요.
cd ~/ros2_ws/src/my_first_pkg/my_first_pkg
nano red_tracker.py

열리면 아래 코드를 그대로 붙여넣으세요.
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image
from cv_bridge import CvBridge
import cv2
import numpy as np

class RedTracker(Node):
    def __init__(self):
        super().__init__('red_tracker')
        self.bridge = CvBridge()

        self.subscription = self.create_subscription(
            Image,
            '/camera/camera/color/image_raw',
            self.image_callback,
            10
        )

    def image_callback(self, msg):
        frame = self.bridge.imgmsg_to_cv2(msg, desired_encoding='bgr8')

        hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)

        lower_red1 = np.array([0, 120, 70])
        upper_red1 = np.array([10, 255, 255])

        lower_red2 = np.array([170, 120, 70])
        upper_red2 = np.array([180, 255, 255])

        mask1 = cv2.inRange(hsv, lower_red1, upper_red1)
        mask2 = cv2.inRange(hsv, lower_red2, upper_red2)
        mask = mask1 + mask2

        contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

        if contours:
            largest_contour = max(contours, key=cv2.contourArea)

            if cv2.contourArea(largest_contour) > 300:
                x, y, w, h = cv2.boundingRect(largest_contour)
                cx = x + w // 2
                cy = y + h // 2

                cv2.rectangle(frame, (x, y), (x + w, y + h), (0, 255, 0), 2)
                cv2.circle(frame, (cx, cy), 5, (255, 0, 0), -1)

                text = f"({cx}, {cy})"
                cv2.putText(frame, text, (x, y - 10),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)

                self.get_logger().info(f'Red object center: x={cx}, y={cy}')

        cv2.imshow("Red Tracker", frame)
        cv2.waitKey(1)

def main(args=None):
    rclpy.init(args=args)
    node = RedTracker()
    rclpy.spin(node)
    node.destroy_node()
    cv2.destroyAllWindows()
    rclpy.shutdown()

if __name__ == '__main__':
    main()


이 코드가 하는 일은 이렇습니다.

카메라 토픽 /camera/camera/color/image_raw를 받아오고,
빨간색 영역만 마스크로 추출한 뒤,
가장 큰 빨간 물체를 찾아서
그 중심 좌표를 계산해서 화면과 터미널에 보여주기


  그 다음에는 setup.py에 실행 항목을 추가
  다음 파일을 여세요.
cd ~/ros2_ws/src/my_first_pkg
nano setup.py

  entry_points 부분에 이 줄을 추가  
'red_tracker = my_first_pkg.red_tracker:main',
    >>> 아래처럼 되어야

entry_points={
    'console_scripts': [
        'talker = my_first_pkg.talker:main',
        'listener = my_first_pkg.listener:main',
        'red_tracker = my_first_pkg.red_tracker:main',
    ],
},
