#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

// PCA9685 보드 객체 생성
Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver();

// 사용하는 서보모터 스펙에 맞춘 PWM 펄스값 (필요시 미세조정)
#define SERVOMIN  150 // 0도일 때
#define SERVOMAX  600 // 180도일 때

void setup() {
  Serial.begin(115200);
  
  pwm.begin();
  pwm.setPWMFreq(50); // 아날로그 서보모터 표준 주파수 50Hz
  
  Serial.println("Robot Arm Ready! Waiting for ROS commands...");
}

void loop() {
  // ROS로부터 시리얼 통신 데이터가 들어오면
  if (Serial.available() > 0) {
    String data = Serial.readStringUntil('\n');
    
    // ':' 기준으로 데이터 쪼개기
    int separatorIndex = data.indexOf(':');
    
    if (separatorIndex > 0) {
      int channel = data.substring(0, separatorIndex).toInt();
      int angle = data.substring(separatorIndex + 1).toInt();

      // 안전을 위해 각도를 0~180도로 제한
      angle = constrain(angle, 0, 180);

      // 각도(0~180)를 PCA9685용 펄스 값(150~600)으로 변환
      int pulse = map(angle, 0, 180, SERVOMIN, SERVOMAX);

      // 모터 구동!
      pwm.setPWM(channel, 0, pulse);

      // ROS 쪽으로 잘 움직였다고 에코(Echo) 전송
      Serial.print("Moved Motor [");
      Serial.print(channel);
      Serial.print("] to ");
      Serial.print(angle);
      Serial.println(" degrees");
    }
  }
} 만들기→토픽으로 통신”의 핵심이 완전히 내 것이 된 거야.
