import rclpy
from rclpy.node import Node
from std_msgs.msg import String
import serial

class ArmController(Node):
    def __init__(self):
        super().__init__('arm_controller_node')
        
        # 아두이노 포트 세팅
        self.port = '/dev/ttyACM0'
        self.baudrate = 115200
        
        try:
            self.ser = serial.Serial(self.port, self.baudrate, timeout=1)
            self.get_logger().info('✅ 아두이노 로봇팔 연결 성공!')
        except Exception as e:
            self.get_logger().error(f'❌ 아두이노 연결 실패: {e}')
            self.ser = None

        # Color Tracker가 퍼블리시하는 좌표 구독
        self.subscription = self.create_subscription(
            String, '/target_xy', self.target_callback, 10)

    def target_callback(self, msg):
        if not self.ser or not self.ser.is_open:
            return
        
        try:
            # 전달받은 "X,Y" 텍스트를 분리
            coords = msg.data.split(',')
            cx = int(coords[0])
            
            # X 좌표(화면너비 0~640)를 서보모터 각도(0~180도)로 비례 변환
            # 물체가 화면 오른쪽에 있으면 모터 각도가 커지고, 왼쪽에 있으면 작아짐
            angle = int((cx / 640.0) * 180.0)
            
            # 0번 모터 채널에 각도 전송 ("채널:각도\n" 포맷)
            command = f"0:{angle}\n"
            self.ser.write(command.encode('utf-8'))
            self.get_logger().info(f'목표 X좌표: {cx} ➔ 모터 전송 명령: {command.strip()}')
            
        except Exception as e:
            self.get_logger().error(f'데이터 처리 오류: {e}')

def main():
    rclpy.init()
    node = ArmController()
    rclpy.spin(node)
    
    if node.ser and node.ser.is_open:
        node.ser.close()
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
