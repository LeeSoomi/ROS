import rclpy
from rclpy.node import Node
from std_msgs.msg import String
import serial
import time


class ArmController(Node):
    def __init__(self):
        super().__init__('arm_controller_node')

        # 파라미터 선언 (런타임에서 변경 가능)
        self.declare_parameter('port',      '/dev/ttyACM0')
        self.declare_parameter('baudrate',  115200)
        self.declare_parameter('image_width', 640)
        self.declare_parameter('motor_channel', 0)
        self.declare_parameter('angle_min', 0)
        self.declare_parameter('angle_max', 180)

        self.port          = self.get_parameter('port').get_parameter_value().string_value
        self.baudrate      = self.get_parameter('baudrate').get_parameter_value().integer_value
        self.image_width   = self.get_parameter('image_width').get_parameter_value().integer_value
        self.motor_channel = self.get_parameter('motor_channel').get_parameter_value().integer_value
        self.angle_min     = self.get_parameter('angle_min').get_parameter_value().integer_value
        self.angle_max     = self.get_parameter('angle_max').get_parameter_value().integer_value

        # 아두이노 시리얼 연결
        self.ser = None
        self._connect_serial()

        # Color Tracker가 퍼블리시하는 좌표 구독
        self.subscription = self.create_subscription(
            String, '/target_xy', self.target_callback, 10)

        self.get_logger().info('🦾 로봇팔 컨트롤러 노드 시작!')
        self.get_logger().info(f'🔌 포트: {self.port} | 보드레이트: {self.baudrate}')
        self.get_logger().info(f'⚙️  모터 채널: {self.motor_channel} | 각도 범위: {self.angle_min}~{self.angle_max}도')

    def _connect_serial(self):
        """아두이노 시리얼 연결 (재시도 포함)"""
        for attempt in range(3):
            try:
                self.ser = serial.Serial(self.port, self.baudrate, timeout=1)
                time.sleep(2)  # 아두이노 리셋 대기
                self.get_logger().info('✅ 아두이노 로봇팔 연결 성공!')
                return
            except Exception as e:
                self.get_logger().warn(f'🔄 연결 시도 {attempt + 1}/3 실패: {e}')
                time.sleep(1)
        self.get_logger().error('❌ 아두이노 연결 최종 실패. 시리얼 없이 동작합니다.')
        self.ser = None

    def target_callback(self, msg):
        if not self.ser or not self.ser.is_open:
            self.get_logger().warn('⚠️  시리얼 미연결 상태. 명령 무시.')
            return

        try:
            # 전달받은 "X,Y" 텍스트를 분리
            coords = msg.data.split(',')
            if len(coords) < 2:
                self.get_logger().warn(f'잘못된 좌표 포맷: {msg.data}')
                return

            cx = int(coords[0])
            cy = int(coords[1])

            # X 좌표(0~640)를 서보모터 각도(0~180도)로 비례 변환
            angle = int((cx / float(self.image_width)) * self.angle_max)
            angle = max(self.angle_min, min(self.angle_max, angle))  # 클램핑

            # 아두이노로 명령 전송 ("채널:각도\n" 포맷)
            command = f"{self.motor_channel}:{angle}\n"
            self.ser.write(command.encode('utf-8'))

            # 아두이노 응답 수신 (있을 경우)
            if self.ser.in_waiting > 0:
                response = self.ser.readline().decode('utf-8').strip()
                self.get_logger().info(f'🤖 아두이노 응답: {response}')

            self.get_logger().info(
                f'📍 수신 좌표: X={cx}, Y={cy} ➔ 각도: {angle}도 ➔ 전송: {command.strip()}')

        except ValueError as e:
            self.get_logger().error(f'좌표 변환 오류: {e}')
        except serial.SerialException as e:
            self.get_logger().error(f'시리얼 통신 오류: {e}')
            self.ser = None
        except Exception as e:
            self.get_logger().error(f'데이터 처리 오류: {e}')


def main():
    rclpy.init()
    node = ArmController()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        node.get_logger().info('🛑 노드 종료 요청')
    finally:
        if node.ser and node.ser.is_open:
            node.ser.close()
            node.get_logger().info('🔌 시리얼 포트 닫힘')
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
